	"edges": [
		{
			"id": "47e782733e5d4b5d",
			"fromNode": "dacd22dc98de4714",
			"fromSide": "right",
			"toNode": "bfde68c64c634b3d",
			"toSide": "left",
			"label": "What are these labeled blocks in a math textbook?"
		},
		{
			"id": "2e69437e99644930",
			"fromNode": "bfde68c64c634b3d",
			"fromSide": "right",
			"toNode": "23fa44801cfa4ed5",
			"toSide": "left",
			"label": "Why can't I just use my intuition for what a word means?"
		},
		{
			"id": "a8302a813fc3495c",
			"fromNode": "bfde68c64c634b3d",
			"fromSide": "right",
			"toNode": "b797ff4e25e54977",
			"toSide": "left",
			"label": "What should I do right after I read a new definition?"
		},
		{
			"id": "9e7d6274c31e4c87",
			"fromNode": "bfde68c64c634b3d",
			"fromSide": "right",
			"toNode": "54e53989c02d421b",
			"toSide": "left",
			"label": "Once we have definitions, what do we do with them?"
		},
		{
			"id": "0628e2b259ef4e45",
			"fromNode": "23fa44801cfa4ed5",
			"fromSide": "right",
			"toNode": "aaac96932a964ac5",
			"toSide": "left",
			"label": "What can I say about quirky numbers using only the definition?"
		},
		{
			"id": "8d6348902cf24766",
			"fromNode": "23fa44801cfa4ed5",
			"fromSide": "right",
			"toNode": "a0d960e83a354174",
			"toSide": "left",
			"label": "How do mathematicians organize the objects they define?"
		},
		{
			"id": "1443c544b03f466a",
			"fromNode": "b797ff4e25e54977",
			"fromSide": "right",
			"toNode": "43e12b3e74534598",
			"toSide": "left",
			"label": "Can I write my own precise definition?"
		},
		{
			"id": "ce25152f376e47f6",
			"fromNode": "b797ff4e25e54977",
			"fromSide": "right",
			"toNode": "239f1b5f16f448d3",
			"toSide": "left",
			"label": "Can I generate examples for a definition I haven't seen before?"
		},
		{
			"id": "f74d4e8189c3409d",
			"fromNode": "54e53989c02d421b",
			"fromSide": "right",
			"toNode": "c71e2d1f6f8040e4",
			"toSide": "left",
			"label": "How reliable are these results?"
		},
		{
			"id": "d58380e954e14d33",
			"fromNode": "54e53989c02d421b",
			"fromSide": "right",
			"toNode": "e388629a77af490a",
			"toSide": "left",
			"label": "How do I use a theorem — can I always apply it?"
		},
		{
			"id": "20d90fe983d14a6a",
			"fromNode": "c71e2d1f6f8040e4",
			"fromSide": "right",
			"toNode": "9fe7b770ff734fec",
			"toSide": "left",
			"label": "How can anything be absolutely certain?"
		},
		{
			"id": "6e9597ca88ee41d2",
			"fromNode": "e388629a77af490a",
			"fromSide": "right",
			"toNode": "29597a90e14c42e1",
			"toSide": "left",
			"label": "Can I identify hypothesis and conclusion in practice?"
		},
		{
			"id": "c11708f8e7aa44bf",
			"fromNode": "e388629a77af490a",
			"fromSide": "right",
			"toNode": "aaac96932a964ac5",
			"toSide": "left",
			"label": "Can I state my own result and label its parts?"
		},
		{
			"id": "b7a88c40eb0545c5",
			"fromNode": "e388629a77af490a",
			"fromSide": "right",
			"toNode": "455c74b1ac154220",
			"toSide": "left",
			"label": "Can I dissect statements about an unfamiliar concept?"
		},
		{
			"id": "7b76a0151fc14671",
			"fromNode": "e388629a77af490a",
			"fromSide": "right",
			"toNode": "2a327e898910476a",
			"toSide": "left",
			"label": "Can I find the hypothesis and conclusion in a less obvious statement?"
		},
		{
			"id": "ac9a4d20e4a6411f",
			"fromNode": "e388629a77af490a",
			"fromSide": "right",
			"toNode": "9394eda4bcf44e07",
			"toSide": "left",
			"label": "What exactly is a 'statement' in mathematics?"
		},
		{
			"id": "88d5da8bfba44ae0",
			"fromNode": "9fe7b770ff734fec",
			"fromSide": "right",
			"toNode": "2f2845e8eb1f4e48",
			"toSide": "left",
			"label": "What does a proof actually look like?"
		},
		{
			"id": "dae2a89f12f14dba",
			"fromNode": "9fe7b770ff734fec",
			"fromSide": "right",
			"toNode": "bd14631fad5c4589",
			"toSide": "left",
			"label": "How should I read a proof to actually understand it?"
		},
		{
			"id": "25e80714a75e4c17",
			"fromNode": "2f2845e8eb1f4e48",
			"fromSide": "right",
			"toNode": "700c081165a84112",
			"toSide": "left",
			"label": "Is proving a theorem the same as applying it?"
		},
		{
			"id": "9d7f0ff8068841b1",
			"fromNode": "2f2845e8eb1f4e48",
			"fromSide": "right",
			"toNode": "4cebc64494464294",
			"toSide": "left",
			"label": "How can one argument cover infinitely many cases?"
		},
		{
			"id": "c283346c059c46b9",
			"fromNode": "4cebc64494464294",
			"fromSide": "right",
			"toNode": "54f24c4d797445de",
			"toSide": "left",
			"label": "Can I strengthen a result by weakening its hypothesis?"
		},
		{
			"id": "a9daa343583c4df1",
			"fromNode": "bd14631fad5c4589",
			"fromSide": "right",
			"toNode": "5077022577d24642",
			"toSide": "left",
			"label": "Is restating each line in my own words enough?"
		},
