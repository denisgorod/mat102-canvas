			"toFloating":false,
			"fromNode":"ce6214fefa3a6c97",
			"fromSide":"top",
			"toNode":"ed2b4d56871288ae",
			"toSide":"bottom",
			"label":"But isn't it true that even small children can recognize a small number of objects before knowing what a number actually is?"
		},
